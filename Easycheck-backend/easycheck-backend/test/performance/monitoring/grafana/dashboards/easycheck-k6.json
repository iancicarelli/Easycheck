{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Solicitudes por segundo",
      "datasource": { "type": "prometheus", "uid": "easycheck-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total[30s])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Duración p95 por endpoint",
      "datasource": { "type": "prometheus", "uid": "easycheck-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "max(k6_http_req_duration_p95) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Tasa de errores HTTP",
      "datasource": { "type": "prometheus", "uid": "easycheck-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max(k6_http_req_failed_rate) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Usuarios virtuales",
      "datasource": { "type": "prometheus", "uid": "easycheck-prometheus" },
      "targets": [{ "expr": "k6_vus", "legendFormat": "VUs", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 41,
  "tags": ["easycheck", "k6"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "title": "EasyCheck - k6",
  "uid": "easycheck-k6",
  "version": 1
}
